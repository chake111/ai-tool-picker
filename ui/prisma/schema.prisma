generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserEventAction {
  search
  favorite
  click
}

enum ToolStatus {
  active
  inactive
}

model UserEvent {
  id        BigInt          @id @default(autoincrement())
  action    UserEventAction
  toolId    String?         @map("tool_id")
  keyword   String?
  userId    String?         @map("user_id")
  createdAt DateTime        @default(now()) @map("created_at")

  @@index([action, createdAt], map: "user_events_action_created_at_idx")
  @@index([userId, createdAt], map: "user_events_user_id_created_at_idx")
  @@index([toolId, createdAt], map: "user_events_tool_id_created_at_idx")
  @@map("user_events")
}

model UserFavorite {
  id        BigInt   @id @default(autoincrement())
  userId    String   @map("user_id")
  toolId    String   @map("tool_id")
  name      String
  desc      String
  reason    String
  link      String?
  tags      String[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, toolId], map: "user_favorites_user_id_tool_id_key")
  @@index([userId, updatedAt], map: "user_favorites_user_id_updated_at_idx")
  @@map("user_favorites")
}

model Tool {
  id          String      @id @default(cuid())
  name        String      @unique
  desc        String
  tags        String[]
  useCases    String[]    @map("use_cases")
  targetUsers String[]    @map("target_users")
  link        String
  status      ToolStatus  @default(active)
  updatedAt   DateTime    @updatedAt @map("updated_at")
  embeddings  ToolEmbedding[]

  @@index([status, updatedAt], map: "tools_status_updated_at_idx")
  @@map("tools")
}

model ToolEmbedding {
  id         BigInt   @id @default(autoincrement())
  toolId     String   @map("tool_id")
  model      String
  vector     Float[]
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  sourceHash String   @map("source_hash")
  tool       Tool     @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@unique([toolId, model], map: "tool_embeddings_tool_id_model_key")
  @@index([model, updatedAt], map: "tool_embeddings_model_updated_at_idx")
  @@map("tool_embeddings")
}

model QueryEmbeddingCache {
  id        BigInt   @id @default(autoincrement())
  key       String   @unique
  model     String
  vector    Float[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([model, updatedAt], map: "query_embedding_cache_model_updated_at_idx")
  @@map("query_embedding_cache")
}
